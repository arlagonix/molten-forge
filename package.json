  "version": "1.12.2",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --config electron-builder.json5",
    "build:win": "tsc && vite build && electron-builder --config electron-builder.json5 --win --x64",
